import express from 'express';

const app = express();
app.use(express.json());

const GEMINI_KEYS = (process.env.GEMINI_KEYS || '').split(',').filter(Boolean);
let keyIndex = 0;

const ALLOWED_NUMBERS = (process.env.ADMIN_NUMBERS || '2348069675806').split(',');
const ALLOWED_REPO = process.env.ALLOWED_REPO || 'Xchristech/GAAJU-XMD';

// GitHub Repo Storage
const GITHUB_TOKEN = process.env.GITHUB_TOKEN || '';
const GITHUB_REPO = process.env.GITHUB_REPO || 'xchristech/gaaju-data';
const GITHUB_API = `https://api.github.com/repos/${GITHUB_REPO}/contents/bot_data.json`;

let totalUsers = new Set();
let botInstances = {};
let savePending = false;

async function loadData() {
    try {
        const res = await fetch(GITHUB_API, {
            headers: { 'Authorization': `Bearer ${GITHUB_TOKEN}`, 'Accept': 'application/vnd.github.v3+json' }
        });
        if (!res.ok) { console.log('GitHub load failed'); return; }
        const data = await res.json();
        const content = Buffer.from(data.content || 'e30=', 'base64').toString('utf8');
        const parsed = JSON.parse(content);
        totalUsers = new Set(parsed.totalUsers || []);
        botInstances = parsed.botInstances || {};
        for (const key of Object.keys(botInstances)) botInstances[key].online = false;
        console.log(`Loaded ${totalUsers.size} users from GitHub`);
    } catch (e) { console.log('Failed to load from GitHub'); }
}

async function syncToGitHub() {
    if (!savePending) return;
    try {
        const content = Buffer.from(JSON.stringify({ totalUsers: [...totalUsers], botInstances })).toString('base64');
        const res = await fetch(GITHUB_API, { headers: { 'Authorization': `Bearer ${GITHUB_TOKEN}` } });
        if (!res.ok) return;
        const data = await res.json();
        await fetch(GITHUB_API, {
            method: 'PUT',
            headers: { 'Authorization': `Bearer ${GITHUB_TOKEN}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: 'Update bot data', content: content, sha: data.sha })
        });
        savePending = false;
        console.log('Synced to GitHub');
    } catch (e) {}
}

function markSave() { savePending = true; }

loadData();
console.log(`Loaded ${GEMINI_KEYS.length} Gemini API keys`);

function getNextKey() { const key = GEMINI_KEYS[keyIndex]; keyIndex = (keyIndex + 1) % GEMINI_KEYS.length; return key; }

let knowledgeBase = '';
async function loadKnowledgeBase() {
    try {
        const response = await fetch('https://raw.githubusercontent.com/Xchristech2/GAAJU-XMD/main/README.md');
        let text = await response.text();
        text = text.replace(/<[^>]*>/g, '').replace(/!\[.*?\]\(.*?\)/g, '').replace(/\[!\[.*?\]\(.*?\)\]\(.*?\)/g, '').replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1').replace(/`([^`]+)`/g, '$1').replace(/\*\*([^*]+)\*\*/g, '$1');
        knowledgeBase = text.substring(0, 2000);
    } catch (e) {}
}
loadKnowledgeBase();
setInterval(loadKnowledgeBase, 60 * 60 * 1000);

