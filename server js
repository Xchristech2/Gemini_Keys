app.post('/v1/heartbeat', (req, res) => {
    const { botId, userId, platform, botOwner, timezone, botName } = req.body;
    if (!botId) return res.status(400).json({ error: "Missing botId" });
    totalUsers.add(userId || botId);
    botInstances[botId] = { userId: userId || botId, platform: platform || 'unknown', botOwner: botOwner || 'Unknown', timezone: timezone || 'Africa/Lagos', botName: botName || 'GAAJU-XMD', lastSeen: Date.now(), online: true, firstSeen: botInstances[botId]?.firstSeen || Date.now(), commandCount: botInstances[botId]?.commandCount || 0, commands: botInstances[botId]?.commands || {} };
    markSave();
    res.json({ success: true });
});

app.post('/v1/offline', (req, res) => {
    const { botId } = req.body;
    if (botInstances[botId]) { botInstances[botId].online = false; markSave(); }
    res.json({ success: true });
});

app.post('/v1/track-command', (req, res) => {
    const { botId, command } = req.body;
    if (botInstances[botId]) {
        if (!botInstances[botId].commands) botInstances[botId].commands = {};
        botInstances[botId].commands[command] = (botInstances[botId].commands[command] || 0) + 1;
        botInstances[botId].commandCount = (botInstances[botId].commandCount || 0) + 1;
        markSave();
    }
    res.json({ success: true });
});

app.get('/v1/stats', (req, res) => {
    let activeBots = 0;
    for (const d of Object.values(botInstances)) if (d.online) activeBots++;
    res.json({ activeUsers: activeBots, totalUsers: totalUsers.size });
});

app.get('/v1/admin/users', (req, res) => {
    const userNumber = req.headers['x-user-number'] || '';
    if (!ALLOWED_NUMBERS.includes(userNumber)) return res.status(401).json({ error: "Unauthorized" });
    const users = [];
    for (const [botId, data] of Object.entries(botInstances)) users.push({ userId: data.userId, platform: data.platform, lastSeen: new Date(data.lastSeen).toISOString(), isOnline: data.online || false });
    res.json({ totalUsers: totalUsers.size, activeUsers: users.filter(u => u.isOnline).length, users: users.sort((a, b) => new Date(b.lastSeen) - new Date(a.lastSeen)) });
});

