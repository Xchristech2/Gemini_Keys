import express from 'express';

const app = express();
app.use(express.json());

const GEMINI_KEYS = (process.env.GEMINI_KEYS || '').split(',').filter(Boolean);
let keyIndex = 0;

console.log(`Loaded ${GEMINI_KEYS.length} Gemini API keys`);

function getNextKey() {
    const key = GEMINI_KEYS[keyIndex];
    keyIndex = (keyIndex + 1) % GEMINI_KEYS.length;
    return key;
}

let knowledgeBase = '';

async function loadKnowledgeBase() {
    try {
        const response = await fetch(
            'https://raw.githubusercontent.com/wallyjaytechh/WALLYJAYTECH-MD/main/README.md'
        );
        let text = await response.text();
        text = text.replace(/<[^>]*>/g, '');
        text = text.replace(/!\[.*?\]\(.*?\)/g, '');
        text = text.replace(/\[!\[.*?\]\(.*?\)\]\(.*?\)/g, '');
        text = text.replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1');
        text = text.replace(/`([^`]+)`/g, '$1');
        text = text.replace(/\*\*([^*]+)\*\*/g, '$1');
        knowledgeBase = text.substring(0, 2000);
        console.log('Knowledge base loaded');
    } catch (e) {
        console.log('Failed to load knowledge base');
    }
}

loadKnowledgeBase();
setInterval(loadKnowledgeBase, 60 * 60 * 1000);

app.get('/', (req, res) => {
    res.send("WALLYJAYTECH-MD Proxy is running!");
});

app.post('/v1/gemini', async (req, res) => {
    try {
        const { prompt } = req.body;
        if (!prompt) return res.status(400).json({ error: "Prompt required" });

        const origin = req.headers['x-bot-origin'] || '';
        if (!origin.includes('wallyjaytechh') || !origin.includes('WALLYJAYTECH-MD')) {
            return res.status(401).json({ error: "Unauthorized. Use official WALLYJAYTECH-MD." });
        }

        const systemPrompt = `You are a helpful AI assistant named WALLYJAYTECH-MD.

When asked about yourself, use this information:
${knowledgeBase}

For general questions, answer normally as a helpful AI.

STRICT FORMATTING RULES:
- ONLY format text that is 25 characters or LESS. If a word/phrase is over 25 characters, do NOT format it at all.
- *bold*: The ENTIRE line must be just *the bold text* (under 25 chars). Never mix bold with plain text on the same line.
- _italic_: The ENTIRE line must be just _the italic text_ (under 25 chars). Never mix italic with plain text on the same line.
- ~strikethrough~: Same rules as bold/italic.
- Triple backticks for code: Same rules.
- • for bullet points.
- --- on its own line for section dividers.
- Use emojis naturally in your responses frequently, friendly and interactively.
- NEVER create border designs (no ╭╰├◇◆★☆♪).
- NEVER let any formatting span across two lines.
- NEVER put formatted and unformatted text on the same line.
- EXCEPTION: When a line starts with a keyword followed by : (like *Keyword:* rest of text), only bold the keyword before the colon. The rest stays plain.

User: ${prompt}`;

        let reply = '';
        let success = false;

        for (let i = 0; i < GEMINI_KEYS.length; i++) {
            try {
                const key = getNextKey();
                
                const response = await fetch(
                    `https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent`,
                    {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-goog-api-key': key
                        },
                        body: JSON.stringify({
                            contents: [{ parts: [{ text: systemPrompt }] }]
                        })
                    }
                );
                const data = await response.json();
                
                reply = data.candidates?.[0]?.content?.parts?.[0]?.text;
                if (reply) {
                    success = true;
                    break;
                }
            } catch (e) {}
        }

        if (!success) {
            return res.status(429).json({ error: "All API keys exhausted. Try again later." });
        }

        res.json({ reply });
    } catch (error) {
        console.error('Gemini error:', error);
        res.status(500).json({ error: "Failed to connect to Gemini" });
    }
});

const PORT = process.env.PORT || 3000;
const MY_URL = 'https://gemini-proxy-10a1.onrender.com';

app.listen(PORT, () => {
    console.log(`Proxy running on port ${PORT}`);
    setInterval(async () => {
        try { await fetch(MY_URL); } catch (e) {}
    }, 12 * 60 * 1000);
});
