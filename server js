app.post('/v1/gemini', async (req, res) => {
    try {
        const repo = req.headers['x-bot-repo'] || '';
        if (repo !== ALLOWED_REPO) return res.status(401).json({ error: "Unauthorized. Use official GAAJU-XMD." });
        const { prompt } = req.body;
        if (!prompt) return res.status(400).json({ error: "Prompt required" });
        const systemPrompt = `You are a professional AI assistant. STRICT RULES:
1. Use ONLY single * for bold headings. NEVER use **.
2. Bold headings must be the ONLY text on their line.
3. Never mix bold and plain text on the same line.
4. If a heading exceeds 25 chars, split into multiple *bold* lines.
5. ALWAYS bold words followed by : at line start (e.g., *Name:* value).
6. Never use _italic_, ~strikethrough~, ---, or any markdown.
7. Use • for bullet points.
8. Separate sections with blank lines only.
9. Keep each line under 30 characters.
10. Use emojis naturally.
11. Never dump raw markdown or tables.
12. Never introduce yourself unless asked.
13. Always write URLs in full.

Info: ${knowledgeBase}. User: ${prompt}`;
        let reply = '', success = false;
        for (let i = 0; i < GEMINI_KEYS.length; i++) {
            try {
                const key = getNextKey();
                const r = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent`, { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-goog-api-key': key }, body: JSON.stringify({ contents: [{ parts: [{ text: systemPrompt }] }] }) });
                const d = await r.json();
                reply = d.candidates?.[0]?.content?.parts?.[0]?.text;
                if (reply) { success = true; break; }
            } catch (e) {}
        }
        if (!success) return res.status(429).json({ error: "All API keys exhausted." });
        res.json({ reply });
    } catch (e) { res.status(500).json({ error: "Failed" }); }
});

app.post('/v1/gpt', async (req, res) => {
    try {
        const repo = req.headers['x-bot-repo'] || '';
        if (repo !== ALLOWED_REPO) return res.status(401).json({ error: "Unauthorized. Use official GAAJU-XMD." });
        const { prompt } = req.body;
        if (!prompt) return res.status(400).json({ error: "Prompt required" });
        const systemPrompt = `Give a detailed, comprehensive answer. Use *bold* for headings on their own line, • for bullets, and blank lines between sections. Never use ** or _italic_. Keep lines short. Info about GAAJU-XMD: ${knowledgeBase}. User: ${prompt}`;

        let reply = '';
        for (let attempt = 0; attempt < 3; attempt++) {
            try {
                const response = await fetch('https://text.pollinations.ai/openai', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ model: 'openai', messages: [{ role: 'user', content: systemPrompt }] })
                });
                const data = await response.json();
                reply = data.choices?.[0]?.message?.content;
                if (reply && reply.length > 20) break;
                await new Promise(r => setTimeout(r, 2000));
            } catch (e) {}
        }
        res.json({ reply: reply || 'GPT is busy. Try again.' });
    } catch (e) { res.status(500).json({ error: "Failed" }); }
});
